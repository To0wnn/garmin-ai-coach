INFLUXDB_URL=http://localhost:8086
INFLUXDB_DB=GarminStats
# WATCH_DEVICE / LOCAL_TZ / LANGUAGE / provider are configurable from the
# dashboard's Settings page after first startup (persisted to
# coach-home/coach_settings.json) — these values are only used as the
# initial defaults on a fresh install.
WATCH_DEVICE=fenix 8 - 47mm, AMOLED
LOCAL_TZ=Europe/Amsterdam
LANGUAGE=English
DASHBOARD_PORT=8420
# Claude Code: alternative to logging in via the dashboard's Settings page —
# generate with `docker compose run --rm --entrypoint claude garmin-ai-coach setup-token`
CLAUDE_CODE_OAUTH_TOKEN=
# Gemini CLI: only needed if you prefer an API key over logging in via the
# dashboard's Settings page.
GEMINI_API_KEY=
DISCORD_WEBHOOK_URL=
