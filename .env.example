# Required for first boot only — creates the initial admin account. After
# that, log in via the dashboard and these two are no longer read.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=

# First-run defaults for the admin account's settings (language, timezone,
# watch device, Discord webhook) — all editable from the dashboard's Settings
# page afterward, and irrelevant for any user who registers later via an
# invite link (they get neutral defaults, not these).
WATCH_DEVICE=fenix 8 - 47mm, AMOLED
LOCAL_TZ=Europe/Amsterdam
LANGUAGE=English
DISCORD_WEBHOOK_URL=
DASHBOARD_PORT=8420

# Claude Code: alternative to logging in via the dashboard's Settings page —
# generate with `docker compose run --rm --entrypoint claude garmin-ai-coach setup-token`
CLAUDE_CODE_OAUTH_TOKEN=
# Gemini CLI (Antigravity): only needed if you prefer an API key over logging
# in via the dashboard's Settings page.
GEMINI_API_KEY=
